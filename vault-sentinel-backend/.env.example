# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vaultsentinel

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (change these in production) ─────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret
LINK_TOKEN_SECRET=change-this-link-secret-too
JWT_ALGORITHM=HS256

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# IMPORTANT: Use a Gmail App Password, NOT your normal Gmail password.
# Steps: myaccount.google.com → Security → 2-Step Verification → App passwords
# Create one for "Mail", paste the 16-char code below (no spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youremail@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
FROM_EMAIL=youremail@gmail.com

# ─── Google Gemini API ────────────────────────────────────────────────────────
# Get free key at: aistudio.google.com
# If not set, rule-based fallback summaries are used automatically.
GEMINI_API_KEY=your-gemini-api-key-here

# ─── NVD CVE API ─────────────────────────────────────────────────────────────
NVD_API_KEY=your-nvd-api-key-here

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─── Security Thresholds ──────────────────────────────────────────────────────
# Endpoints scoring above this are auto-quarantined (GHOST class)
QUARANTINE_THRESHOLD=85

# ─── Auto-Scan Scheduler ──────────────────────────────────────────────────────
# How often to automatically scan all clients (in minutes)
SCAN_INTERVAL_MINUTES=5

# ─── Victim Server ────────────────────────────────────────────────────────────
VICTIM_SERVER_URL=http://localhost:8001
